library(ggplot2)
library(gganimate)
library(gifski)
library(grid)
# -----------------------------
# Brand / layout settings
# -----------------------------
bg_col        <- "#282934"
depth_col     <- "#343645"
line_col      <- "#F3F5F7"
star_col      <- "#93DCFF"
accent_arc    <- "#BCDDED"
title_text    <- "ARC Lab"
subtitle_text <- "Advancing Research in Corrections Lab"
topics_text   <- "Corrections  •  Reentry  •  Assessment  •  Evaluation"
# -----------------------------
# Generate data for exponential curve
# -----------------------------
n <- 220
x <- seq(1, 40, length.out = n)
# Slightly earlier and stronger rise
y_raw <- 5 * exp(0.115 * (x - 36))
# Normalize into plotting space
y <- (y_raw - min(y_raw)) / (max(y_raw) - min(y_raw))
y <- 0.02 + 0.90 * y
curve_data <- data.frame(
frame = seq_len(n),
x = x,
y = y
)
# cumulative line (for drawing effect)
line_data <- do.call(
rbind,
lapply(seq_len(n), function(i) {
data.frame(frame = i, x = x[1:i], y = y[1:i])
})
)
# star follows curve
star_data <- curve_data
# endpoint glow
end_x <- max(x)
end_y <- y[length(y)]
# -----------------------------
# Plot
# -----------------------------
p <- ggplot() +
# depth background
annotate(
"rect",
xmin = -Inf, xmax = Inf,
ymin = -Inf, ymax = Inf,
fill = depth_col,
alpha = 0.10
) +
# endpoint glow
annotate("point", x = end_x, y = end_y,
size = 34, color = star_col, alpha = 0.045) +
annotate("point", x = end_x, y = end_y,
size = 20, color = star_col, alpha = 0.08) +
# faint background curve
geom_path(
data = data2,
aes(x = x, y = y),
color = accent_arc,
linewidth = 1.0,
alpha = 0.12,
lineend = "round"
) +
# animated main curve
geom_path(
data = line_data,
aes(x = x, y = y, group = frame),
color = line_col,
linewidth = 2.8,
lineend = "round"
) +
# spark glow layers
geom_point(data = star_data, aes(x = x, y = y),
color = star_col, size = 24, shape = 8, alpha = 0.05) +
geom_point(data = star_data, aes(x = x, y = y),
color = star_col, size = 16, shape = 8, alpha = 0.12) +
geom_point(data = star_data, aes(x = x, y = y),
color = star_col, size = 9, shape = 8, alpha = 0.24) +
geom_point(data = star_data, aes(x = x, y = y),
color = star_col, size = 6, shape = 8) +
# -----------------------------
# FIXED TEXT BLOCK (clean spacing)
# -----------------------------
annotate(
"text",
x = 20.5, y = 0.88,
label = title_text,
color = "#F5F7FA",
size = 32,
hjust = 0.5,
fontface = "bold"
) +
annotate(
"text",
x = 20.5, y = 0.74,
label = subtitle_text,
color = "#E2E6ED",
size = 9,
hjust = 0.5,
fontface = "bold"
) +
annotate(
"segment",
x = 17.2, xend = 23.8,
y = 0.67, yend = 0.67,
color = "#6F7684",
linewidth = 0.3,
alpha = 0.6
) +
annotate(
"text",
x = 20.5, y = 0.58,
label = topics_text,
color = "#B8BEC9",
size = 6.5,
hjust = 0.5
) +
coord_cartesian(
xlim = c(0, 42),
ylim = c(0, 1),
clip = "off"
) +
theme_void() +
theme(
plot.background = element_rect(fill = bg_col, color = NA),
panel.background = element_rect(fill = bg_col, color = NA),
plot.margin = margin(18, 25, 18, 25)
) +
transition_manual(frame)
