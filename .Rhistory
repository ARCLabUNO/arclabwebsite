title_text    <- "ARC Lab"
subtitle_text <- "Advancing Research in Corrections Lab"
topics_text   <- "Corrections  •  Reentry  •  Assessment  •  Evaluation"
# -----------------------------
# Generate data for exponential curve
# -----------------------------
n <- 220
x <- seq(1, 40, length.out = n)
# Slightly earlier and stronger rise
y_raw <- 5 * exp(0.115 * (x - 36))
